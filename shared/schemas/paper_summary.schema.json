{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperSummary",
  "type": "object",
  "required": ["paper_id", "title", "summary", "keywords", "citations"],
  "properties": {
    "paper_id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" }
        }
      }
    }
  }
}

